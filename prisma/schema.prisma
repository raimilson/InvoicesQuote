generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MEMBER
}

enum Currency {
  USD
  CAD
  BRL
  EUR
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  CONVERTED
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  role       UserRole @default(MEMBER)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model Company {
  id                  String              @id @default(uuid())
  name                String
  address             String
  ein                 String?
  is_default          Boolean             @default(false)
  invoices            Invoice[]
  quotes              Quote[]
  order_confirmations OrderConfirmation[]
  delivery_notices    DeliveryNotice[]
  packing_lists       PackingList[]
  sales_contracts     SalesContract[]
  created_at          DateTime            @default(now())
}

model Client {
  id                  String              @id @default(uuid())
  name                String
  company             String?
  address             String?
  phone               String?
  email               String?
  notes               String?
  invoices            Invoice[]
  quotes              Quote[]
  order_confirmations OrderConfirmation[]
  delivery_notices    DeliveryNotice[]
  packing_lists       PackingList[]
  sales_contracts     SalesContract[]
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt
}

model BankTemplate {
  id              String          @id @default(uuid())
  name            String
  currency        Currency
  account_number  String
  institution_no  String?
  transit_no      String?
  swift_bic       String?
  bank_name       String
  bank_address    String
  is_default      Boolean         @default(false)
  invoices        Invoice[]
  sales_contracts SalesContract[]
  created_at      DateTime        @default(now())
}

model Quote {
  id                  String              @id @default(uuid())
  quote_number        String              @unique
  client              Client              @relation(fields: [client_id], references: [id])
  client_id           String
  company             Company?            @relation(fields: [company_id], references: [id])
  company_id          String?
  date                DateTime
  valid_until         DateTime
  status              QuoteStatus         @default(DRAFT)
  currency            String              @default("USD")
  line_items          Json
  subtotal            Decimal             @db.Decimal(12, 2)
  tax                 Decimal?            @db.Decimal(12, 2)
  total               Decimal             @db.Decimal(12, 2)
  notes               String?
  payment_terms       String?
  converted_to        Invoice?            @relation("QuoteToInvoice", fields: [converted_to_id], references: [id])
  converted_to_id     String?             @unique
  order_confirmations OrderConfirmation[]
  deleted_at          DateTime?
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt
}

model Invoice {
  id                  String              @id @default(uuid())
  invoice_number      String              @unique
  client              Client              @relation(fields: [client_id], references: [id])
  client_id           String
  company             Company?            @relation(fields: [company_id], references: [id])
  company_id          String?
  from_quote          Quote?              @relation("QuoteToInvoice")
  date                DateTime
  due_date            DateTime
  status              InvoiceStatus       @default(DRAFT)
  bank_template       BankTemplate        @relation(fields: [bank_template_id], references: [id])
  bank_template_id    String
  line_items          Json
  subtotal            Decimal             @db.Decimal(12, 2)
  tax                 Decimal?            @db.Decimal(12, 2)
  total               Decimal             @db.Decimal(12, 2)
  payment_terms       String?
  notes               String?
  payments            Payment[]
  order_confirmations OrderConfirmation[]
  delivery_notices    DeliveryNotice[]
  packing_lists       PackingList[]
  sales_contracts     SalesContract[]
  deleted_at          DateTime?
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt
}

model Payment {
  id         String   @id @default(uuid())
  invoice    Invoice  @relation(fields: [invoice_id], references: [id])
  invoice_id String
  amount     Decimal  @db.Decimal(12, 2)
  date       DateTime
  method     String
  notes      String?
  created_at DateTime @default(now())
}

model OrderConfirmation {
  id             String    @id @default(uuid())
  order_number   String    @unique
  invoice        Invoice?  @relation(fields: [invoice_id], references: [id])
  invoice_id     String?
  quote          Quote?    @relation(fields: [quote_id], references: [id])
  quote_id       String?
  client         Client    @relation(fields: [client_id], references: [id])
  client_id      String
  company        Company?  @relation(fields: [company_id], references: [id])
  company_id     String?
  date           DateTime
  delivery_date  DateTime?
  payment_terms  String?
  currency       String    @default("USD")
  purchase_order String?
  line_items     Json
  notes          String?
  deleted_at     DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
}

model DeliveryNotice {
  id                 String        @id @default(uuid())
  delivery_number    String        @unique
  invoice            Invoice?      @relation(fields: [invoice_id], references: [id])
  invoice_id         String?
  client             Client        @relation(fields: [client_id], references: [id])
  client_id          String
  company            Company?      @relation(fields: [company_id], references: [id])
  company_id         String?
  date               DateTime
  purchase_order     String?
  purchase_date      DateTime?
  commercial_invoice String?
  shipment_type      String?
  tracking_number    String?
  incoterms          String?
  country_of_origin  String?
  line_items         Json
  notes              String?
  packing_lists      PackingList[]
  deleted_at         DateTime?
  created_at         DateTime      @default(now())
  updated_at         DateTime      @updatedAt
}

model PackingList {
  id             String          @id @default(uuid())
  packing_number String          @unique
  invoice        Invoice?        @relation(fields: [invoice_id], references: [id])
  invoice_id     String?
  delivery       DeliveryNotice? @relation(fields: [delivery_id], references: [id])
  delivery_id    String?
  client         Client          @relation(fields: [client_id], references: [id])
  client_id      String
  company        Company?        @relation(fields: [company_id], references: [id])
  company_id     String?
  date           DateTime
  line_items     Json
  cartons        Json
  notes          String?
  deleted_at     DateTime?
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt
}

model SalesContract {
  id                  String        @id @default(uuid())
  contract_number     String        @unique
  invoice             Invoice?      @relation(fields: [invoice_id], references: [id])
  invoice_id          String?
  client              Client        @relation(fields: [client_id], references: [id])
  client_id           String
  company             Company?      @relation(fields: [company_id], references: [id])
  company_id          String?
  bank_template       BankTemplate? @relation(fields: [bank_template_id], references: [id])
  bank_template_id    String?
  date                DateTime
  currency            String        @default("USD")
  line_items          Json
  total               Decimal       @default(0) @db.Decimal(12, 2)
  notes               String?
  client_vat_id       String?
  client_bank_name    String?
  client_bank_address String?
  client_account      String?
  client_swift        String?
  deleted_at          DateTime?
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt
}
